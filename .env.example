# ============================================================================
# CLERK AUTHENTICATION
# ============================================================================
# Get these from https://dashboard.clerk.com
# 1. Go to Settings → API Keys
# 2. Copy Publishable Key
# 3. Copy Secret Key
# 4. Go to Webhooks → Create Endpoint
#    URL: https://yourdomain.com/api/webhooks/clerk
#    Events: user.created, user.updated, user.deleted
#    Copy Signing Secret
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ============================================================================
# SUPABASE DATABASE
# ============================================================================
# Get these from https://app.supabase.com
# 1. Create new project
# 2. Go to Settings → API
# 3. Copy Project URL and Anon Key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ============================================================================
# RESEND EMAIL SERVICE
# ============================================================================
# Get this from https://resend.com
# 1. Create account
# 2. Go to API Keys
# 3. Copy API Key
RESEND_API_KEY=re_...

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Omar Clinic Pro
NEXT_PUBLIC_APP_LOGO_URL=https://yourdomain.com/logo.png

# ============================================================================
# DATABASE CONNECTION (Optional - for direct database access)
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/omar_clinic_pro

# ============================================================================
# VERCEL DEPLOYMENT
# ============================================================================
# Set automatically by Vercel during deployment
VERCEL_URL=
VERCEL_ENV=production

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================
NODE_ENV=development

# ============================================================================
# LOGGING & DEBUGGING
# ============================================================================
DEBUG=false
LOG_LEVEL=info
